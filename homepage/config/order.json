        {
            "name": "project",
            "label": "Projekt",
            "type": "Relation",
            "required": true,
            "reference": "/api/v1/projects?all=true",
            "labelField": "name",
            "valueField": "slug"
        },
        {
            "name": "name",
            "label": "Vor- und Nachname",
            "type": "Text",
            "required": true
        },
        {
            "name": "email",
            "label": "E-Mail-Adresse",
            "type": "Text",
            "required": true,
            "validation": {
                "expression": "/^\\S+@\\S+\\.\\S+$/.test(email)",
                "message": "Bitte gib eine gültige E-Mail-Adresse ein."
            }
        },
        {
            "name": "phone",
            "label": "Telefonnummer",
            "type": "Text"
        },
        {
            "name": "street",
            "label": "Straße und Hausnummer",
            "type": "Text",
            "required": true
        },
        {
            "name": "zip",
            "label": "PLZ",
            "type": "Text",
            "required": true
        },
        {
            "name": "city",
            "label": "Stadt",
            "type": "Text",
            "required": true,
            "default": "Ulm"
        },
        {
            "name": "specialAddress",
            "label": "Dies ist eine Sonderadresse (z.B. Schrebergarten ohne reguläre Hausnummer)",
            "type": "Boolean",
            "default": false
        },
        {
            "name": "offering",
            "label": "Gewünschter Baum",
            "type": "OfferingSelector",
            "reference": "/api/v1/offerings",
            "required": true
        },
        {
            "name": "quantity",
            "label": "Anzahl",
            "type": "Integer",
            "required": true,
            "default": 1
        },
        {
            "name": "selectedAddons",
            "label": "Zusatzoptionen",
            "type": "Tags",
            "readonly": true
        },
        {
            "name": "gardenType",
            "label": "Pflanzort",
            "type": "Select",
            "options": [
                "Privatgarten",
                "Gewerbefläche",
                "Gemeinschaftsgarten",
                "Sonstiges"
            ]
        },
        {
            "name": "notes",
            "label": "Anmerkungen",
            "type": "Text"
        },
        {
            "name": "status",
            "label": "Status",
            "type": "Select",
            "options": [
                "neu",
                "bestätigt",
                "ausgegeben",
                "storniert"
            ],
            "default": "neu"
        },
        {
            "name": "agb",
            "label": "Ich akzeptiere die Teilnahmebedingungen",
            "type": "Boolean",
            "required": true
        }
    ],
    "grid": [
        "project project name name",
