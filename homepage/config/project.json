{
    "entity": "project",
    "slug": "projekte",
    "menuOrder": 40,
    "api": "/api/v1/projects",
    "label": {
        "singular": "Projekt",
        "plural": "Projekte"
    },
    "jsonld": {
        "@type": "Event",
        "mapping": {
            "name": "name",
            "description": "text",
            "url": "slug"
        }
    },
    "icon": "Folder",
    "admin": {
        "columns": [
            {
                "key": "name",
                "label": "Name"
            },
            {
                "key": "slug",
                "label": "Slug"
            },
            {
                "key": "active",
                "label": "Aktiv",
                "type": "boolean"
            }
        ]
    },
    "fields": [
        {
            "name": "name",
            "label": "Projektname",
            "type": "Text",
            "required": true
        },
        {
            "name": "slug",
            "label": "URL-Slug",
            "type": "Text",
            "required": true
        },
        {
            "name": "text",
            "label": "Kurztext",
            "type": "Textarea",
            "description": "Wird auf der Projekt-Card angezeigt"
        },

        {
            "name": "orderFormConfig",
            "label": "Bestellformular-Config",
            "type": "Text"
        },
        {
            "name": "active",
            "label": "Aktiv",
            "type": "Boolean",
            "default": true
        },
        {
            "name": "content.timeline",
            "label": "Zeitstrahl (Ablauf)",
            "type": "ObjectArray",
            "description": "Erstelle hier die einzelnen Meilensteine des Projektablaufs.",
            "itemFields": [
                {
                    "name": "date",
                    "label": "Datum",
                    "type": "Date",
                    "required": true
                },
                {
                    "name": "label",
                    "label": "Titel",
                    "type": "Text",
                    "required": true
                },
                {
                    "name": "description",
                    "label": "Beschreibung",
                    "type": "Text"
                },
                {
                    "name": "status",
                    "label": "Status",
                    "type": "Select",
                    "options": [
                        {
                            "value": "upcoming",
                            "label": "Geplant (leer)"
                        },
                        {
                            "value": "active",
                            "label": "Aktuell (pulsierend)"
                        },
                        {
                            "value": "done",
                            "label": "Abgeschlossen (Häkchen)"
                        }
                    ],
                    "default": "upcoming"
                }
            ]
        },
        {
            "name": "content.team",
            "label": "Unser Team",
            "type": "ObjectArray",
            "description": "Füge hier Teammitglieder für dieses Projekt hinzu.",
            "itemFields": [
                {
                    "name": "name",
                    "label": "Name",
                    "type": "Text",
                    "required": true
                },
                {
                    "name": "role",
                    "label": "Rolle / Position",
                    "type": "Text",
                    "required": true
                },
                {
                    "name": "avatar",
                    "label": "Profilbild",
                    "type": "Media"
                }
            ]
        },
        {
            "name": "content.sponsors",
            "label": "Partner & Sponsoren",
            "type": "ObjectArray",
            "description": "Füge hier Partner und Sponsoren hinzu.",
            "itemFields": [
                {
                    "name": "name",
                    "label": "Name",
                    "type": "Text",
                    "required": true
                },
                {
                    "name": "url",
                    "label": "Website URL",
                    "type": "Text"
                },
                {
                    "name": "logo",
                    "label": "Logo",
                    "type": "Media"
                }
            ]
        }
    ],
    "grid": [
        "name name slug slug",
        "orderFormConfig orderFormConfig active .",
        "text text text text",
        "content.timeline content.timeline content.team content.team",
        "content.sponsors content.sponsors . ."
    ],
    "resource": "projects"
}
