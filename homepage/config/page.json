        {
            "name": "wideLayout",
            "label": "Breites Layout",
            "type": "Boolean",
            "default": false,
            "hint": "Aktivieren für Seiten mit Karten-Grids (Bäume, Projekte, Beiträge)"
        },
        {
            "name": "content",
            "label": "Seiteninhalt (HTML)",
            "type": "Html"
        }
    ],
    "grid": [
        "image image image image",
        "project project title title",
        "slug slug heroSubtitle heroSubtitle",
